   Autor: Ian Oliveira
   ========================================== */

/* FATURAMENTO TOTAL */
SELECT
    SUM([VALOR]) AS FATURAMENTO_TOTAL
FROM ['Projeto Restaurante$'];

/* PRATOS MAIS VENDIDOS POR MÊS */
SELECT
    MONTH(DATA) AS MES,
    PRATO,
    SUM(QUANTIDADE) AS TOTAL_VENDIDO
FROM ['Projeto Restaurante$']
GROUP BY MONTH(DATA), PRATO
ORDER BY MES, TOTAL_VENDIDO DESC;

/* TICKET MÉDIO MENSAL */
SELECT
    MONTH(DATA) AS MES,
    AVG([VALOR]) AS TICKET_MEDIO
FROM ['Projeto Restaurante$']
GROUP BY MONTH(DATA)
ORDER BY TICKET_MEDIO DESC;

/* CONSUMO DE BEBIDAS */
SELECT
    BEBIDA,
    COUNT(BEBIDA) AS QUANTIDADES
FROM ['Projeto Restaurante$']
GROUP BY BEBIDA
ORDER BY QUANTIDADES DESC;

/* TOP 10 CLIENTES */
SELECT TOP 10
    CLIENTE,
    SUM([VALOR]) AS TOTAL_GASTO
FROM ['Projeto Restaurante$']
GROUP BY CLIENTE
ORDER BY TOTAL_GASTO DESC;

/* FATURAMENTO MENSAL */
SELECT
    MONTH(DATA) AS MES,
    SUM([VALOR]) AS FATURAMENTO_TOTAL
FROM ['Projeto Restaurante$']
GROUP BY MONTH(DATA)
ORDER BY FATURAMENTO_TOTAL DESC;

/* PRATOS COM MAIOR FATURAMENTO */
SELECT
    PRATO,
    SUM(QUANTIDADE) AS TOTAL_VENDIDO,
    SUM([VALOR]) AS FATURAMENTO
FROM ['Projeto Restaurante$']
GROUP BY PRATO
ORDER BY FATURAMENTO DESC;

/* TOTAL DE PEDIDOS */
SELECT
    COUNT(DISTINCT ID) AS PEDIDOS_UNICOS
FROM ['Projeto Restaurante$'];

/* CLIENTES ÚNICOS */
SELECT
    COUNT(DISTINCT CLIENTE) AS CLIENTES_UNICOS
FROM ['Projeto Restaurante$'];
